{
  "name": "ai-feishu",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && vite build",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "init-db": "tsx scripts/init-db.ts",
    "reset-demo": "bash scripts/reset-local-demo.sh",
    "test:performance": "vitest run tests/performance",
    "test:load": "autocannon -c 10 -d 30 http://localhost:3000/health",
    "analyze:perf": "tsx scripts/analyze-response-times.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.62",
    "@ai-sdk/openai": "^3.0.52",
    "@hono/node-server": "^1.19.13",
    "@lancedb/lancedb": "^0.27.0",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^0.1.0",
    "@larksuiteoapi/node-sdk": "^1.5.0",
    "ai": "^3.0.0",
    "apache-arrow": "^21.1.0",
    "better-sqlite3": "^12.0.0",
    "hono": "^4.0.0",
    "langchain": "^1.3.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "uuid": "^13.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autocannon": "^7.15.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "5.7.3",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
