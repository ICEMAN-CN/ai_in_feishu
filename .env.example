# Copy to .env and adjust: cp .env.example .env
#
# --- Admin UI login (same value in browser "API Key" field) ---
ADMIN_API_KEY=demo-admin-login
#
# --- Must be exactly 64 hex chars; keep stable or existing encrypted DB breaks ---
# Generate new: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
#
# --- Feishu (required for bot) ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
#
# Optional
# DATA_DIR=./data
# PORT=3000
